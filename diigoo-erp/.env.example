# ─── Diigoo ERP — environment template ───
# Copy to .env and adjust. The web app runs standalone with MOCK data by default.

# Data adapter for the Next.js BFF: "mock" (in-memory seed, no DB needed) or "core" (calls the Rust core service)
DATA_ADAPTER=mock

# Rust core service (used when DATA_ADAPTER=core)
CORE_API_URL=http://localhost:8080

# PostgreSQL (used by the Rust core)
DATABASE_URL=postgres://diigoo:diigoo@localhost:5432/diigoo_erp
POSTGRES_USER=diigoo
POSTGRES_PASSWORD=diigoo
POSTGRES_DB=diigoo_erp

# Auth / signing (demo values — replace in production)
JWT_SECRET=dev-only-change-me-in-production-please-32b
JWT_ISSUER=diigoo-erp

# Default tenant used by seed data
DEFAULT_TENANT_ID=t_diigoo_demo
DEFAULT_TENANT_TIER=enterprise
